# 访问密码（留空则不需要密码）
ACCESS_PASSWORD=

# 服务端口
PORT=3001

# JWT 密钥（生产环境务必修改）
JWT_SECRET=your-jwt-secret-here

# DMXApi 基础 URL
DMXAPI_BASE_URL=https://www.dmxapi.cn

# 站长 API Key（余额模式使用）
OWNER_API_KEY=your-dmxapi-key-here

# 管理员密钥（用于手动充值等管理操作）
ADMIN_KEY=

# SMTP 邮件配置（用于发送验证码）
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your-email@qq.com
SMTP_PASS=your-smtp-password

# 支付配置（虎皮椒支付）
PAY_APP_ID=
PAY_APP_SECRET=
PAY_NOTIFY_URL=
PAY_API_URL=https://api.xunhupay.com/payment/do.html
